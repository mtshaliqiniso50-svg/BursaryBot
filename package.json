{
  "name": "bursarybot-fullstack",
  "version": "1.0.0",
  "description": "BursaryBot with Aiven MySQL - Full Stack",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
